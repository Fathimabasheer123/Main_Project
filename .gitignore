# ============================================
# MEDCHAIN — .gitignore
# Django + Ethereum + AI/ML + Hardhat + Ganache
# ============================================


# ============================================
# CRITICAL SECURITY FILES (NEVER UPLOAD!)
# ============================================
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
secret_key.txt
private_key.txt
mnemonic.txt
wallet_key.txt


# ============================================
# AI MODELS — Large binary files
# NEVER upload — regenerate by running notebooks
# Each .pkl file can be 50–300MB
# GitHub rejects files over 100MB
# ============================================
*.pkl
*.joblib
*.h5
*.hdf5
*.onnx
*.pt
*.pth
models_trained/
apps/ai_engine/models_trained/


# ============================================
# AI DATASETS — Large CSV/data files
# Download from Kaggle when needed
# ============================================
datasets/
data/
apps/ai_engine/datasets/
*.csv
*.tsv
X_test.csv
X_train.csv


# ============================================
# AI OUTPUT FILES
# Auto-generated plots — not needed in Git
# ============================================
outputs/
apps/ai_engine/outputs/
shap_beeswarm.png
shap_waterfall.png
stage1_*.png
stage2_*.png
stage3_*.png
lime_explanation_*.html


# ============================================
# JUPYTER NOTEBOOKS
# Checkpoint files auto-generated by Jupyter
# ============================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/
**/.ipynb_checkpoints/


# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
venv/
env/
ENV/
.venv
venv*/
env*/
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg
*.egg
.python-version
Pipfile.lock
poetry.lock


# ============================================
# Test files
# ============================================
test_blockchain_manual.py
tests/
.pytest_cache/
pytest_cache/
.coverage
coverage.xml
htmlcov/
nosetests.xml


# ============================================
# Django
# ============================================
db.sqlite3
db.sqlite3-journal
db.sqlite3-shm
db.sqlite3-wal
*.log
local_settings.py
media/
staticfiles/
static_root/
collected_static/
generated_pdfs/
prescription_pdfs/
qr_codes/
*.pdf


# ============================================
# Node.js
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
.yarn/
.yarn-integrity
.node_repl_history
*.tgz


# ============================================
# Hardhat / Blockchain
# ============================================
artifacts/
cache/
coverage/
typechain/
typechain-types/
dist/
bundle/
ignition/
deployments/

# Ganache local blockchain data
.ganache/
ganache-data/
ganache_db/
ganache-workspace/

# Smart contract source and compiled artifacts
apps/blockchain/contracts/*.json
contracts/*.sol
apps/blockchain/contracts/PrescriptionStorage.sol
apps/blockchain/hardhat.config.cjs


# ============================================
# IDE & Editors
# ============================================
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.#*
*.sublime-project
*.sublime-workspace
.spyderproject.db
.ropeproject/


# ============================================
# OS Files
# ============================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
Icon

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*
.fuse_hidden*


# ============================================
# Build & Deployment
# ============================================
build/
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo
.cache/
.parcel-cache/


# ============================================
# Backup & Temporary Files
# ============================================
*.bak
*.backup
*.tmp
*.temp
*.old
*.orig
~$*


# ============================================
# NOTE — Files intentionally NOT ignored
# ============================================
# requirements.txt  — needed to install Python packages
# package.json      — needed to install Node packages
# hardhat.config.js — needed to deploy smart contract
# apps/*/migrations/— needed to recreate database schema
# ============================================